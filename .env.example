# ===========================================
# RepoForge 环境变量配置模板
# ===========================================

# ----------------------------
# OpenAI 兼容 API 配置（必填）
# ----------------------------
# 支持以下提供商：
# - DeepSeek: https://api.deepseek.com (推荐模型: deepseek-chat)
# - StepFun: https://api.stepfun.com/v1 (推荐模型: step-3.5-flash, step-1, step-1v)
# - Azure OpenAI, 或其他兼容 OpenAI 协议的服务
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.deepseek.com
# 模型名称（两种变量名都支持，推荐使用 OPENAI_MODEL_NAME）
MODEL_ID=deepseek-chat
OPENAI_MODEL_NAME=step-3.5-flash

# ----------------------------
# 飞书机器人配置（必填）
# ----------------------------
FEISHU_APP_ID=cli_xxxxxx
FEISHU_APP_SECRET=your_secret_here

# ----------------------------
# GitHub 配置（跨仓库克隆和 PR 创建需要）
# ----------------------------
GITHUB_TOKEN=ghp_xxxxxxxxxxxx
GITHUB_REPO=your_org/your_repo  # 默认仓库，可被 [repo:xxx] 覆盖

# ----------------------------
# 可选配置
# ----------------------------
# 本地代码库路径（用于 worktree 创建，默认项目根目录）
# TARGET_REPO_PATH=/path/to/local/repo

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# Prometheus 指标暴露端口，设为空字符串禁用
PROMETHEUS_PORT=8000

# 🔥 并发控制：最大同时运行的任务数（建议5-10）
# 根据机器配置调整：
#   - 4GB 内存：3-4
#   - 8GB 内存：6-8
#   - 16GB+ 内存：10-12
MAX_CONCURRENT_TASKS=5
