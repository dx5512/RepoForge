{
  "dashboard": {
    "title": "RepoForge Metrics",
    "uid": "repoforge-metrics",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "5s",
    "time": { "from": "now-1h", "to": "now" },
    "panels": [
      {
        "id": 1,
        "title": "Active Tasks",
        "type": "gauge",
        "targets": [
          {
            "expr": "repoforge_active_tasks",
            "legendFormat": "Active Tasks"
          }
        ],
        "gridPos": { "x": 0, "y": 0, "w": 6, "h": 6 },
        "fieldConfig": { "defaults": { "unit": "short", "min": 0 } }
      },
      {
        "id": 2,
        "title": "Task Duration (p50, p95)",
        "type": "timeseries",
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(repoforge_task_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(repoforge_task_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "p95"
          }
        ],
        "gridPos": { "x": 6, "y": 0, "w": 12, "h": 8 },
        "yaxes": { "unit": "s" }
      },
      {
        "id": 3,
        "title": "Tasks Started vs Completed (rate)",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(repoforge_tasks_started_total[5m])",
            "legendFormat": "Started"
          },
          {
            "expr": "rate(repoforge_tasks_completed_total[5m])",
            "legendFormat": "Completed"
          }
        ],
        "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 }
      },
      {
        "id": 4,
        "title": "Task Completion Status",
        "type": "barchart",
        "targets": [
          {
            "expr": "sum(rate(repoforge_tasks_completed_total[5m])) by (status)",
            "legendFormat": "{{status}}"
          }
        ],
        "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 }
      },
      {
        "id": 5,
        "title": "Agent Iterations",
        "type": "timeseries",
        "targets": [
          {
            "expr": "sum(rate(repoforge_agent_iterations_total[5m])) by (agent)",
            "legendFormat": "{{agent}}"
          }
        ],
        "gridPos": { "x": 12, "y": 4, "w": 6, "h": 4 }
      },
      {
        "id": 6,
        "title": "Container Operations (rate)",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(repoforge_container_create_total[5m])",
            "legendFormat": "Create"
          },
          {
            "expr": "rate(repoforge_container_destroy_total[5m])",
            "legendFormat": "Destroy"
          }
        ],
        "gridPos": { "x": 0, "y": 14, "w": 12, "h": 6 }
      },
      {
        "id": 7,
        "title": "Worktree Operations (rate)",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(repoforge_worktree_create_total[5m])",
            "legendFormat": "Create"
          },
          {
            "expr": "rate(repoforge_worktree_remove_total[5m])",
            "legendFormat": "Remove"
          }
        ],
        "gridPos": { "x": 12, "y": 14, "w": 12, "h": 6 }
      }
    ]
  }
}
